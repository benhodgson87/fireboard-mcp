{
  "name": "fireboard-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Fireboard BBQ temperature monitoring API",
  "license": "ISC",
  "author": "Ben Hodgson (work@benhodgson.net)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && rm -rf dist/views && cp -r src/views dist/views",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.19.0",
    "winston": "^3.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
